async function nweLoadModalChart(sym, tf) {
  const h = parseFloat($('nweBw').value), mult = parseFloat($('nweMult').value);
  $('nweMCenter').textContent = '...';
  try {
    const { opens, highs, lows, closes } = await nweGetKlinesFull(sym, tf);
    const { nwe, maeArr, out, upper, lower } = nweComputeNWE(closes, h, mult);
    const sig = nweDetectSignal(closes, nwe, maeArr, nweLookbackForTF(tf));
    nweDrawChart({ opens, highs, lows, closes, nwe, maeArr });
    $('nweMCenter').textContent = nweFormatPrice(out);
    $('nweMUpper').textContent  = nweFormatPrice(upper);
    $('nweMLower').textContent  = nweFormatPrice(lower);
    $('nweMSig').textContent    = sig.isBuy?'▲ Alım':sig.isSell?'▼ Satım':'— Nötr';
    $('nweMSig').style.color    = sig.isBuy?'var(--mat)':sig.isSell?'var(--danger)':'var(--text-faint)';
  } catch(e) { $('nweMCenter').textContent='Hata'; }
}

function nweDrawChart({ opens, highs, lows, closes, nwe, maeArr }) {
  const canvas = $('nweModalCanvas');
  const DPR = window.devicePixelRatio||1;
  const W = canvas.parentElement.offsetWidth-32;
  const H = Math.min(420, window.innerHeight-220);
  canvas.width = W*DPR; canvas.height = H*DPR;
  canvas.style.width = W+'px'; canvas.style.height = H+'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(DPR, DPR);
  const PAD = {l:70,r:16,t:20,b:30};
  ctx.fillStyle='#0f131e'; ctx.fillRect(0,0,W,H);

  const n = closes.length;
  const upperArr = nwe.map((v,i)=>v+maeArr[i]);
  const lowerArr = nwe.map((v,i)=>v-maeArr[i]);
  const allV = [...highs,...lows,...upperArr,...lowerArr];
  const minV=Math.min(...allV), maxV=Math.max(...allV), range=maxV-minV||1;
  const py = v => PAD.t+(1-(v-minV)/range)*(H-PAD.t-PAD.b);
  const cw = (W-PAD.l-PAD.r)/n;
  const px = i => PAD.l+i*cw+cw/2;

  ctx.strokeStyle='#1d2434'; ctx.lineWidth=0.5;
  for(let i=0;i<=5;i++){
    const y=PAD.t+i*(H-PAD.t-PAD.b)/5;
    ctx.beginPath();ctx.moveTo(PAD.l,y);ctx.lineTo(W-PAD.r,y);ctx.stroke();
    ctx.fillStyle='#525a6e';ctx.font='10px JetBrains Mono,monospace';ctx.textAlign='right';
    ctx.fillText(nweFormatPrice(maxV-i*range/5),PAD.l-4,y+3);
  }

  ctx.beginPath();
  for(let i=0;i<n;i++){const x=px(i);i===0?ctx.moveTo(x,py(upperArr[i])):ctx.lineTo(x,py(upperArr[i]));}
  for(let i=n-1;i>=0;i--) ctx.lineTo(px(i),py(lowerArr[i]));
  ctx.closePath(); ctx.fillStyle='rgba(216,184,119,0.05)'; ctx.fill();

  ctx.lineWidth=1.5;
  ctx.strokeStyle='rgba(67,221,139,0.8)';
  ctx.beginPath();
  for(let i=0;i<n;i++){const x=px(i),y=py(upperArr[i]);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}
  ctx.stroke();
  ctx.strokeStyle='rgba(255,93,114,0.8)';
  ctx.beginPath();
  for(let i=0;i<n;i++){const x=px(i),y=py(lowerArr[i]);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}
  ctx.stroke();

  ctx.strokeStyle='rgba(216,184,119,0.5)'; ctx.lineWidth=1; ctx.setLineDash([4,3]);
  ctx.beginPath();
  for(let i=0;i<n;i++){const x=px(i),y=py(nwe[i]);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}
  ctx.stroke(); ctx.setLineDash([]);

  const cw2=Math.max(1,cw*0.7);
  for(let i=0;i<n;i++){
    const x=px(i), isUp=closes[i]>=opens[i], col=isUp?'#43dd8b':'#ff5d72';
    ctx.strokeStyle=col; ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(x,py(highs[i]));ctx.lineTo(x,py(lows[i]));ctx.stroke();
    const bT=py(Math.max(opens[i],closes[i])), bB=py(Math.min(opens[i],closes[i]));
    ctx.fillStyle=col; ctx.fillRect(x-cw2/2,bT,cw2,Math.max(1,bB-bT));
  }

  for(let i=1;i<n;i++){
    if(closes[i-1]<lowerArr[i-1]&&closes[i]>=lowerArr[i]){
      ctx.fillStyle='#43dd8b';ctx.font='bold 13px Arial';ctx.textAlign='center';
      ctx.fillText('▲',px(i),py(lows[i])+16);
    }
    if(closes[i-1]>upperArr[i-1]&&closes[i]<=upperArr[i]){
      ctx.fillStyle='#ff5d72';ctx.font='bold 13px Arial';ctx.textAlign='center';
      ctx.fillText('▼',px(i),py(highs[i])-6);
    }
  }
}

