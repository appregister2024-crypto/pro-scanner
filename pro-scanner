  nweActiveSymbolsCache = set; nweActiveSymbolsCacheTime = Date.now();
  return set;
}

let nweMcapCache = null, nweMcapCacheTime = 0;
async function nweGetMarketCapRank() {
  if (nweMcapCache && Date.now() - nweMcapCacheTime < 10*60*1000) return nweMcapCache;
  const map = new Map();
  try {
    for (const page of [1, 2]) {
      const r = await fetch(`https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=250&page=${page}&sparkline=false`);
      if (!r.ok) break;
      const d = await r.json();
      if (!Array.isArray(d) || d.length === 0) break;
      for (const c of d) {
        const sym = (c.symbol || '').toUpperCase();
        if (!map.has(sym) && c.market_cap) map.set(sym, c.market_cap);
      }
    }
  } catch (e) {}
  nweMcapCache = map; nweMcapCacheTime = Date.now();
  return map;
}

async function nweGetTopSymbols(n) {
  const [r, activeSymbols, mcap] = await Promise.all([
    fetch('https://api.binance.com/api/v3/ticker/24hr'), nweGetActiveSymbols(), nweGetMarketCapRank()
  ]);
  const d = await r.json();
  const filtered = d.filter(t => t.symbol.endsWith('USDT') && activeSymbols.has(t.symbol) &&
    !['UP','DOWN','BEAR','BULL'].some(x => t.symbol.includes(x)));
  if (mcap.size > 0) {
    filtered.sort((a,b) => {
      const base = s => s.symbol.slice(0, -4);
      return (mcap.get(base(b)) || 0) - (mcap.get(base(a)) || 0);
    });
  } else {
    filtered.sort((a,b) => parseFloat(b.quoteVolume)-parseFloat(a.quoteVolume));
  }
  return filtered.slice(0, n).map(t => ({ symbol: t.symbol, price: parseFloat(t.lastPrice) }));
}

function nweResampleKlines(rawKlines, factor) {
  if (factor <= 1) return rawKlines;
  const out = [];
  const usableLen = Math.floor(rawKlines.length / factor) * factor;
  const trimmed = rawKlines.slice(rawKlines.length - usableLen);
  for (let i = 0; i < trimmed.length; i += factor) {
    const group = trimmed.slice(i, i + factor);
    out.push([group[0][0], parseFloat(group[0][1]), Math.max(...group.map(k => parseFloat(k[2]))), Math.min(...group.map(k => parseFloat(k[3]))), parseFloat(group[group.length-1][4])]);
  }
  return out;
}

async function nweFetchRawKlines(symbol, tf) {
  const cfg = NWE_TF_CONFIG[tf];
  const fetchLimit = Math.min(1000, cfg.bars * cfg.resample + cfg.resample);
  const r = await fetch(`https://api.binance.com/api/v3/klines?symbol=${symbol}&interval=${cfg.api}&limit=${fetchLimit}`);
  if (!r.ok) throw new Error('fetch fail');
  return await r.json();
}
async function nweGetKlines(symbol, tf) {
  const cfg = NWE_TF_CONFIG[tf];
  const resampled = nweResampleKlines(await nweFetchRawKlines(symbol, tf), cfg.resample);
  return resampled.map(k => k[4]);
}
async function nweGetKlinesFull(symbol, tf) {
  const cfg = NWE_TF_CONFIG[tf];
  const resampled = nweResampleKlines(await nweFetchRawKlines(symbol, tf), cfg.resample);
  return { opens: resampled.map(k=>k[1]), highs: resampled.map(k=>k[2]), lows: resampled.map(k=>k[3]), closes: resampled.map(k=>k[4]), times: resampled.map(k=>k[0]) };
}

