<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pro Scanner — Diamond &amp; Bullish Mat Hold &amp; DCA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#05060a; --surface:#0c0f18; --surface-hi:#12172400; --card:#0f131e; --card-hi:#151b29;
    --line:#1d2434; --line-soft:#161c2a;
    --text:#eef1f8; --text-dim:#8b93a8; --text-faint:#525a6e;
    --gold:#d8b877; --gold-soft:#8a7443; --gold-glow:rgba(216,184,119,0.35);
    --diamond:#8fe7ff; --diamond-dim:#3c7688;
    --mat:#43dd8b; --mat-dim:#22513a;
    --dcabear:#ff9f43; --dcabear-dim:#5c3a1a; /* dca-bear renk teması */
    --dcabull:#7c83ff; --dcabull-dim:#332f66; /* dca-bull renk teması */
    --danger:#ff5d72; --danger-dim:#5c2530;
    --font-display:'Space Grotesk',sans-serif; --font-mono:'JetBrains Mono',monospace; --font-body:'Inter',sans-serif;
  }
  *{ box-sizing:border-box; }
  html,body{ margin:0; background:var(--bg); color:var(--text); font-family:var(--font-body); overflow-x:hidden; }
  body{
    background:
      radial-gradient(ellipse 900px 500px at 15% -10%, rgba(216,184,119,0.07), transparent 60%),
      radial-gradient(ellipse 800px 600px at 110% 10%, rgba(143,231,255,0.06), transparent 60%),
      var(--bg);
    min-height:100vh;
  }
  #wrap{ max-width:1080px; margin:0 auto; padding:28px 20px 70px; }

  /* ---------- Header ---------- */
  header{ display:flex; align-items:center; gap:20px; padding:6px 2px 26px; border-bottom:1px solid var(--line-soft); margin-bottom:26px; }
  .gem{ width:56px; height:56px; flex:none; filter:drop-shadow(0 0 14px rgba(143,231,255,0.25)); }
  .gem.scanning{ animation:gemPulse 1.4s ease-in-out infinite; }
  @keyframes gemPulse{ 0%,100%{ filter:drop-shadow(0 0 14px rgba(143,231,255,0.25)); } 50%{ filter:drop-shadow(0 0 26px rgba(216,184,119,0.55)); } }
  .htext h1{ font-family:var(--font-display); font-size:23px; font-weight:700; margin:0 0 3px; letter-spacing:0.2px; }
  .htext h1 span{ color:var(--gold); }
  .htext p{ margin:0; font-size:12.5px; color:var(--text-dim); font-family:var(--font-mono); letter-spacing:0.3px; }

  /* ---------- Cards ---------- */
  .card{ background:linear-gradient(180deg,var(--card),var(--card) 60%,#0d111b); border:1px solid var(--line); border-radius:16px; padding:20px 22px; margin-bottom:18px; }
  .card-title{ font-family:var(--font-display); font-size:13px; font-weight:600; color:var(--text-dim); text-transform:uppercase; letter-spacing:1.2px; margin:0 0 14px; display:flex; align-items:center; gap:8px; }
  .card-title i{ width:5px; height:5px; border-radius:50%; background:var(--gold); display:inline-block; box-shadow:0 0 8px var(--gold-glow); }

  /* ---------- Controls ---------- */
  .field-row{ display:flex; flex-wrap:wrap; gap:22px; }
  .field{ flex:1; min-width:230px; }
  .field label{ display:block; font-size:11px; font-family:var(--font-mono); color:var(--text-faint); text-transform:uppercase; letter-spacing:1px; margin-bottom:9px; }
  .chip-group{ display:flex; flex-wrap:wrap; gap:7px; }
  .chip{
    font-family:var(--font-mono); font-size:12px; font-weight:500; color:var(--text-dim);
    background:#0b0e17; border:1px solid var(--line); padding:7px 13px; border-radius:9px;
    cursor:pointer; user-select:none; transition:all .15s ease; letter-spacing:0.2px;
  }
  .chip:hover{ border-color:var(--gold-soft); color:var(--text); }
  .chip.active{ background:linear-gradient(180deg,#1a2130,#141a26); border-color:var(--gold); color:var(--gold); box-shadow:0 0 0 1px rgba(216,184,119,0.15) inset; }
  .chip.active.tf{ border-color:var(--diamond); color:var(--diamond); box-shadow:0 0 0 1px rgba(143,231,255,0.15) inset; }
  .chip.active.p-diamond{ border-color:var(--diamond); color:var(--diamond); box-shadow:0 0 0 1px rgba(143,231,255,0.15) inset; }
  .chip.active.p-mat{ border-color:var(--mat); color:var(--mat); box-shadow:0 0 0 1px rgba(67,221,139,0.15) inset; }
  .chip.active.p-dca{ border-color:var(--dcabear); color:var(--dcabear); box-shadow:0 0 0 1px rgba(255,159,67,0.15) inset; }
  .custom-n{ display:none; align-items:center; gap:8px; margin-top:9px; }
  .custom-n.show{ display:flex; }
  .custom-n input{
    width:90px; background:#0b0e17; border:1px solid var(--line); color:var(--text); border-radius:8px;
    padding:7px 10px; font-family:var(--font-mono); font-size:12.5px;
  }
  .custom-n span{ font-size:11px; color:var(--text-faint); font-family:var(--font-mono); }

  /* ---------- Scan button + progress ---------- */
  .scan-row{ display:flex; align-items:center; gap:16px; margin-top:20px; flex-wrap:wrap; }
  #scanBtn, #nweScanBtn{
    font-family:var(--font-display); font-weight:600; font-size:14px; color:#0a0c12;
    background:linear-gradient(135deg,var(--gold),#f0d9a5); border:none; border-radius:11px;
    padding:12px 26px; cursor:pointer; letter-spacing:0.3px; transition:transform .12s ease, box-shadow .12s ease;
    box-shadow:0 6px 20px -6px rgba(216,184,119,0.5);
  }
  #scanBtn:hover, #nweScanBtn:hover{ transform:translateY(-1px); box-shadow:0 8px 24px -6px rgba(216,184,119,0.65); }
  #scanBtn.stop, #nweScanBtn.stop{ background:linear-gradient(135deg,var(--danger),#ff8a97); box-shadow:0 6px 20px -6px rgba(255,93,114,0.5); }
  #scanBtn:disabled, #nweScanBtn:disabled{ opacity:0.55; cursor:not-allowed; transform:none; }

  .prog-wrap{ flex:1; min-width:240px; }
  #phaseText, #nwePhaseText{ font-family:var(--font-mono); font-size:11.5px; color:var(--text-dim); margin-bottom:6px; display:flex; justify-content:space-between; }
  #phaseText b, #nwePhaseText b{ color:var(--diamond); font-weight:600; }
  .bar{ height:6px; background:#0b0e17; border:1px solid var(--line); border-radius:6px; overflow:hidden; }
  .bar > div{ height:100%; width:0%; background:linear-gradient(90deg,var(--diamond-dim),var(--diamond),var(--gold)); transition:width .25s ease; }

  /* ---------- Stats ---------- */
  .stats{ display:flex; gap:14px; flex-wrap:wrap; margin-top:16px; }
  .stat{ flex:1; min-width:130px; background:#0b0e17; border:1px solid var(--line); border-radius:11px; padding:12px 15px; }
  .stat .n{ font-family:var(--font-mono); font-size:20px; font-weight:700; color:var(--text); }
  .stat .l{ font-size:10.5px; color:var(--text-faint); text-transform:uppercase; letter-spacing:0.8px; margin-top:2px; }
  .stat.diamond .n{ color:var(--diamond); }
  .stat.mat .n{ color:var(--mat); }
  .stat.dca .n{ color:var(--dcabear); }

  /* ---------- Results toolbar ---------- */
  .toolbar{ display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:16px; }
  .toolbar .chip-group{ flex:none; }
  .search-box{ position:relative; flex:1; min-width:160px; }
  .search-box input{
    width:100%; background:#0b0e17; border:1px solid var(--line); color:var(--text); border-radius:9px;
    padding:8px 12px 8px 30px; font-family:var(--font-mono); font-size:12.5px;
  }
  .search-box::before{ content:'⌕'; position:absolute; left:11px; top:50%; transform:translateY(-50%); color:var(--text-faint); font-size:13px; }
  .btn-ghost{
    font-family:var(--font-mono); font-size:12px; color:var(--text-dim); background:#0b0e17;
    border:1px solid var(--line); border-radius:9px; padding:8px 14px; cursor:pointer; white-space:nowrap;
    display:inline-flex; align-items:center; gap:6px; transition:all .15s ease;
  }
  .btn-ghost:hover{ border-color:var(--gold-soft); color:var(--gold); }
  .btn-ghost:disabled{ opacity:0.4; cursor:not-allowed; }

  /* ---------- Results table ---------- */
  #resultsCard{ padding-top:20px; }
  table{ width:100%; border-collapse:collapse; font-size:13px; }
  thead th{
    text-align:left; font-family:var(--font-mono); font-size:10.5px; color:var(--text-faint);
    text-transform:uppercase; letter-spacing:0.8px; padding:0 10px 10px; border-bottom:1px solid var(--line);
  }
  tbody td{ padding:11px 10px; border-bottom:1px solid var(--line-soft); }
  tbody tr:hover{ background:#0d1119; }
  .tf-tag{ font-family:var(--font-mono); font-size:11px; color:var(--text-dim); background:#0b0e17; border:1px solid var(--line); padding:3px 8px; border-radius:6px; }
  .coin-link{ font-family:var(--font-mono); font-weight:600; color:var(--text); text-decoration:none; display:inline-flex; align-items:center; gap:5px; }
  .coin-link:hover{ color:var(--gold); }
  .coin-link svg{ width:11px; height:11px; opacity:0.5; }
  .badge{ font-family:var(--font-mono); font-size:11px; font-weight:600; padding:4px 10px; border-radius:20px; display:inline-flex; align-items:center; gap:5px; }
  .badge.diamond{ color:var(--diamond); background:rgba(143,231,255,0.08); border:1px solid var(--diamond-dim); }
  .badge.mat{ color:var(--mat); background:rgba(67,221,139,0.08); border:1px solid var(--mat-dim); }
  .badge.dca-bear{ color:var(--dcabear); background:rgba(255,159,67,0.08); border:1px solid var(--dcabear-dim); }
  .badge.dca-bull{ color:var(--dcabull); background:rgba(124,131,255,0.08); border:1px solid var(--dcabull-dim); }

  #emptyState, #idleState{ text-align:center; padding:50px 10px; color:var(--text-faint); font-size:13px; }
  #emptyState .big, #idleState .big{ font-size:32px; margin-bottom:10px; }

  /* ---------- Legal panel ---------- */
  .legal{ border:1px solid var(--danger-dim); background:linear-gradient(180deg,rgba(255,93,114,0.05),transparent); border-radius:16px; padding:18px 22px; margin-bottom:18px; }
  .legal .lt{ font-family:var(--font-display); font-size:12px; font-weight:700; color:var(--danger); text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }
  .legal p{ margin:0; font-size:12.5px; color:var(--text-dim); line-height:1.7; }
  .legal b{ color:var(--text); }

  footer{ text-align:center; font-size:11px; color:var(--text-faint); font-family:var(--font-mono); margin-top:26px; }

  /* ---------- NWE Scanner ---------- */
  .nwe-cols{ display:flex; gap:16px; flex-wrap:wrap; }
  .nwe-col{ flex:1; min-width:280px; background:#0b0e17; border:1px solid var(--line); border-radius:12px; overflow:hidden; }
  .nwe-col-header{ display:flex; align-items:center; gap:8px; padding:12px 14px; border-bottom:1px solid var(--line-soft); font-family:var(--font-display); font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:1px; }
  .nwe-col-header.buy{ color:var(--mat); }
  .nwe-col-header.sell{ color:var(--danger); }
  .nwe-col-count{ font-family:var(--font-mono); font-size:11px; font-weight:700; padding:2px 9px; border-radius:20px; margin-left:auto; }
  .nwe-col-header.buy .nwe-col-count{ background:rgba(67,221,139,0.1); color:var(--mat); }
  .nwe-col-header.sell .nwe-col-count{ background:rgba(255,93,114,0.1); color:var(--danger); }
  .nwe-sig-list{ max-height:520px; overflow-y:auto; }
  .nwe-sig-card{ display:flex; align-items:center; gap:10px; padding:10px 14px; border-bottom:1px solid var(--line-soft); cursor:pointer; transition:background .1s ease; }
  .nwe-sig-card:hover{ background:#0d1119; }
  .nwe-sig-card.strong{ background:rgba(216,184,119,0.04); }
  .nwe-sig-card.strong:hover{ background:rgba(216,184,119,0.08); }
  .nwe-sig-rank{ font-family:var(--font-mono); font-size:10px; color:var(--text-faint); width:20px; flex-shrink:0; }
  .nwe-sig-sym{ font-family:var(--font-mono); font-weight:700; font-size:13px; flex:1; color:var(--text); }
  .nwe-sig-tfs{ display:flex; gap:4px; flex-wrap:wrap; justify-content:flex-end; }
  .nwe-sig-tf{ font-family:var(--font-mono); font-size:9.5px; font-weight:600; padding:2px 6px; border-radius:4px; }
  .nwe-sig-tf.buy{ background:rgba(67,221,139,0.1); color:var(--mat); }
  .nwe-sig-tf.sell{ background:rgba(255,93,114,0.1); color:var(--danger); }
  .nwe-sig-score{ font-family:var(--font-mono); font-size:10px; font-weight:700; color:var(--gold); background:rgba(216,184,119,0.1); padding:2px 7px; border-radius:5px; flex-shrink:0; }
  .nwe-strong-badge{ font-size:9px; padding:2.5px 7px; background:rgba(143,231,255,0.1); color:var(--diamond); border:1px solid var(--diamond-dim); border-radius:4px; font-weight:700; font-family:var(--font-mono); white-space:nowrap; }
  .nwe-empty-col{ display:flex; flex-direction:column; align-items:center; justify-content:center; padding:48px 20px; color:var(--text-faint); font-size:12.5px; gap:10px; }

  .nwe-mtf-row{ display:flex; align-items:center; gap:12px; padding:11px 14px; border-radius:9px; background:#0b0e17; border:1px solid var(--line); cursor:pointer; transition:background .1s ease; }
  .nwe-mtf-row:hover{ background:#0d1119; }
  .nwe-mtf-row-tf{ font-family:var(--font-mono); font-size:12.5px; font-weight:700; width:48px; flex-shrink:0; color:var(--text); }
  .nwe-mtf-row-bar{ flex:1; height:6px; border-radius:3px; background:#151b29; position:relative; overflow:hidden; }
  .nwe-mtf-row-bar-fill{ position:absolute; top:0; bottom:0; left:0; border-radius:3px; }
  .nwe-mtf-row-status{ font-family:var(--font-mono); font-size:11px; font-weight:700; width:80px; text-align:right; flex-shrink:0; }
  .nwe-mtf-row-status.buy{ color:var(--mat); }
  .nwe-mtf-row-status.sell{ color:var(--danger); }
  .nwe-mtf-row-status.none{ color:var(--text-faint); }

  #nweModal{ display:none; position:fixed; inset:0; background:rgba(5,6,10,0.94); z-index:1000; flex-direction:column; backdrop-filter:blur(2px); }
  #nweModal.open{ display:flex; }
  .nwe-modal-header{ background:var(--card); border-bottom:1px solid var(--line); padding:14px 18px; display:flex; align-items:center; gap:12px; flex-wrap:wrap; }
  .nwe-modal-sym{ font-family:var(--font-mono); font-size:17px; font-weight:700; color:var(--gold); letter-spacing:0.3px; }
  .nwe-modal-price{ font-family:var(--font-mono); font-size:13px; color:var(--text-dim); }
  .nwe-modal-tf-row{ display:flex; gap:6px; margin-left:auto; flex-wrap:wrap; }
  .nwe-modal-tf-btn{ background:#0b0e17; border:1px solid var(--line); color:var(--text-dim); padding:5px 10px; font-family:var(--font-mono); font-size:11px; cursor:pointer; border-radius:6px; font-weight:500; }
  .nwe-modal-tf-btn.active{ background:var(--gold); border-color:var(--gold); color:#0a0c12; font-weight:700; }
  .nwe-modal-body{ flex:1; padding:18px; overflow:auto; }
  #nweModalCanvas{ display:block; width:100%; border-radius:10px; background:var(--card); border:1px solid var(--line); }
  .nwe-modal-stats{ display:flex; gap:14px; padding:14px 18px; border-top:1px solid var(--line-soft); flex-wrap:wrap; background:var(--card); }

  @media (max-width:600px){
    .htext h1{ font-size:19px; }
    .stat{ min-width:100px; }

    /* Filtre chip grubunun ekran dışına taşmasını engelle */
    .toolbar{ overflow-x:hidden; }
    .toolbar .chip-group{ flex:1 1 100%; width:100%; flex-wrap:wrap; }
    .search-box{ flex:1 1 100%; width:100%; }
    .btn-ghost{ flex:1 1 auto; justify-content:center; }
    .nwe-cols{ flex-direction:column; }
  }
</style>
</head>
<body>
<div id="wrap">

  <header>
    <svg class="gem" id="gemIcon" viewBox="0 0 100 100">
      <defs>
        <linearGradient id="gemGrad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#f0d9a5"/>
          <stop offset="45%" stop-color="#8fe7ff"/>
          <stop offset="100%" stop-color="#3c7688"/>
        </linearGradient>
      </defs>
      <polygon points="50,4 92,36 50,96 8,36" fill="url(#gemGrad)" opacity="0.92"/>
      <polyline points="8,36 92,36" stroke="#05060a" stroke-width="1.6" opacity="0.5"/>
      <polyline points="50,4 30,36 50,96" stroke="#05060a" stroke-width="1.6" opacity="0.5"/>
      <polyline points="50,4 70,36 50,96" stroke="#05060a" stroke-width="1.6" opacity="0.5"/>
      <polyline points="30,36 50,60 70,36" stroke="#05060a" stroke-width="1.6" opacity="0.5"/>
    </svg>
    <div class="htext">
      <h1>PRO <span>SCANNER</span></h1>
      <p>DIAMOND &amp; BULLISH MAT HOLD &amp; DCA · CANLI BINANCE TARAMASI</p>
    </div>
  </header>

  <div class="chip-group" id="modeTabs" style="margin-bottom:18px;">
    <div class="chip active" data-mode="pattern">📐 FORMASYON TARAMA</div>
    <div class="chip" data-mode="nwe">📊 NWE TARAMA</div>
  </div>

  <div id="patternView">
  <div class="card">
    <div class="card-title"><i></i>Tarama Ayarları</div>
    <div class="field-row">
      <div class="field">
        <label>Binance Top Hacim Sayısı</label>
        <div class="chip-group" id="topNChips">
          <div class="chip" data-n="50">TOP 50</div>
          <div class="chip active" data-n="100">TOP 100</div>
          <div class="chip" data-n="200">TOP 200</div>
          <div class="chip" data-n="custom">ÖZEL</div>
        </div>
        <div class="custom-n" id="customNWrap">
          <input type="number" id="customNInput" min="10" max="400" value="150">
          <span>coin (10–400)</span>
        </div>
      </div>
      <div class="field">
        <label>Zaman Dilimleri</label>
        <div class="chip-group" id="tfChips">
          <div class="chip tf" data-tf="15m">15 DK</div>
          <div class="chip tf" data-tf="1h">1 SAAT</div>
          <div class="chip tf active" data-tf="4h">4 SAAT</div>
          <div class="chip tf active" data-tf="1d">GÜNLÜK</div>
          <div class="chip tf active" data-tf="1w">HAFTALIK</div>
          <div class="chip tf" data-tf="1M">AYLIK</div>
          <div class="chip tf" data-tf="3M">3 AYLIK</div>
        </div>
      </div>
      <div class="field">
        <label>Formasyonlar</label>
        <div class="chip-group" id="patternChips">
          <div class="chip p-diamond active" data-pattern="diamond">💎 DIAMOND</div>
          <div class="chip p-mat active" data-pattern="mat">🚀 B.M HOLD</div>
          <div class="chip p-dca active" data-pattern="dca">🦉 DCA</div>
        </div>
      </div>
    </div>

    <div class="scan-row">
      <button id="scanBtn">▶ TARAMAYI BAŞLAT</button>
      <div class="prog-wrap">
        <div id="phaseText"><span id="phaseLabel">Hazır</span><span id="phasePct"></span></div>
        <div class="bar"><div id="progFill"></div></div>
      </div>
    </div>

    <div class="stats" id="statsRow" style="display:none;">
      <div class="stat"><div class="n" id="statScanned">0</div><div class="l">Taranan Kayıt</div></div>
      <div class="stat diamond"><div class="n" id="statDiamond">0</div><div class="l">💎 Diamond</div></div>
      <div class="stat mat"><div class="n" id="statMat">0</div><div class="l">🚀 B.M Hold</div></div>
      <div class="stat dca"><div class="n" id="statDcaBear">0</div><div class="l">🦉 DCA</div></div>
      <div class="stat"><div class="n" id="statTime">0s</div><div class="l">Süre</div></div>
    </div>
  </div>

  <div class="card" id="resultsCard">
    <div class="toolbar">
      <div class="chip-group" id="filterChips">
        <div class="chip active" data-filter="all">Tümü</div>
        <div class="chip" data-filter="diamond">💎 Diamond</div>
        <div class="chip" data-filter="mat">🚀 B.M Hold</div>
        <div class="chip" data-filter="dca">🦉 DCA</div>
      </div>
      <div class="search-box"><input id="searchInput" placeholder="Coin ara… (ör. BTC)"></div>
      <button class="btn-ghost" id="csvBtn" disabled>⬇ CSV İndir</button>
      <button class="btn-ghost" id="pngBtn" disabled>🖼 Görsel İndir</button>
    </div>

    <div id="idleState">
      <div class="big">◈</div>
      Taramayı başlatınca formasyonlar burada listelenecek.
    </div>
    <div id="emptyState" style="display:none;">
      <div class="big">—</div>
      Bu taramada aktif formasyon bulunamadı.
    </div>
    <div id="tableWrap" style="display:none; overflow-x:auto;">
      <table>
        <thead><tr><th>Periyot</th><th>Coin</th><th>Formasyon</th></tr></thead>
        <tbody id="resultsBody"></tbody>
      </table>
    </div>
  </div>

