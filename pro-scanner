async function nweRunManualCheck() {
  const symRaw = $('nweManualSym').value.toUpperCase().trim();
  if (!symRaw) return;
  const sym = symRaw.endsWith('USDT') ? symRaw : symRaw + 'USDT';
  const btn = $('nweManualCheckBtn');
  btn.disabled = true; btn.textContent = '⏳';
  const h = parseFloat($('nweBw').value), mult = parseFloat($('nweMult').value);
  const allTFs = Object.keys(NWE_TF_CONFIG);
  const sigMap = {};
  let price = null, failed = 0;
  for (const tf of allTFs) {
    try {
      const closes = await nweGetKlines(sym, tf);
      if (closes.length < 20) { failed++; continue; }
      const { nwe, maeArr } = nweComputeNWE(closes, h, mult);
      sigMap[tf] = nweDetectSignal(closes, nwe, maeArr, nweLookbackForTF(tf));
      if (price === null) price = closes[closes.length-1];
    } catch(e) { failed++; }
  }
  btn.disabled = false; btn.textContent = '🔍 Kontrol Et';
  if (failed === allTFs.length) { alert('Sembol bulunamadı: ' + sym); return; }
  nweManualData = { sym, price, sigMap, tfs: allTFs.filter(tf => sigMap[tf]) };
  nweRenderManualResult();
}

function nweRenderManualResult() {
  const { sym, price, sigMap, tfs } = nweManualData;
  const buyTFs = tfs.filter(tf => sigMap[tf].isBuy);
  const sellTFs = tfs.filter(tf => sigMap[tf].isSell);
  const buyScore = nweComputeScore(buyTFs), sellScore = nweComputeScore(sellTFs);
  const maxWeight = Math.max(...tfs.map(tf=>NWE_TF_WEIGHT[tf]||1));

  $('nweManualTitle').textContent = sym.replace('USDT','') + ' / USDT';
  $('nweManualMeta').textContent = nweFormatPrice(price) + '  ·  ' + tfs.length + ' TF tarandı';
  $('nweMBuyTF').textContent = buyTFs.length;
  $('nweMSellTF').textContent = sellTFs.length;
  $('nweMBuyScore').textContent = '★ '+buyScore;
  $('nweMSellScore').textContent = '★ '+sellScore;

  const tableEl = $('nweManualTable');
  tableEl.innerHTML = '';
  tfs.forEach(tf => {
    const sig = sigMap[tf];
    const w = NWE_TF_WEIGHT[tf] || 1;
    const pct = (w / maxWeight * 100).toFixed(0);
    const status = sig.isBuy ? 'buy' : sig.isSell ? 'sell' : 'none';
    const statusLabel = sig.isBuy ? '▲ ALIM' : sig.isSell ? '▼ SATIM' : '— nötr';
    const barColor = sig.isBuy ? 'var(--mat)' : sig.isSell ? 'var(--danger)' : 'var(--text-faint)';
    const row = document.createElement('div');
    row.className = 'nwe-mtf-row';
    row.innerHTML = `
      <span class="nwe-mtf-row-tf">${NWE_TF_LABEL[tf]}</span>
      <div class="nwe-mtf-row-bar"><div class="nwe-mtf-row-bar-fill" style="width:${pct}%;background:${barColor};opacity:${status==='none'?0.3:0.85}"></div></div>
      <span class="nwe-mtf-row-status ${status}">${statusLabel}</span>
    `;
    row.addEventListener('click', () => {
      const orderedTfs = [tf, ...tfs.filter(t => t !== tf)];
      nweOpenModal({ sym, price, sigMap, tfs: orderedTfs });
    });
    tableEl.appendChild(row);
  });

  $('nweIdleState').style.display = 'none';
  $('nweResultsCard').style.display = 'none';
  $('nweManualResultCard').style.display = '';
}

function nweRoundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x+r, y); ctx.arcTo(x+w, y, x+w, y+h, r); ctx.arcTo(x+w, y+h, x, y+h, r);
  ctx.arcTo(x, y+h, x, y, r); ctx.arcTo(x, y, x+w, y, r); ctx.closePath();
}
function nweFormatPrice(v) {
  if (!v||isNaN(v)) return '—';
  if (v>=1000) return v.toLocaleString('tr-TR',{maximumFractionDigits:2});
  if (v>=1)    return v.toFixed(4);
  if (v>=0.01) return v.toFixed(5);
  return v.toFixed(8);
}

