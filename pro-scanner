/* ================= NWE SCANNER (Nadaraya-Watson Envelope) ================= */
const NWE_BATCH = 5, NWE_DELAY = 120;
const NWE_TF_CONFIG = {
  '1m': {api:'1m',  bars:500, resample:1}, '3m': {api:'3m',  bars:500, resample:1},
  '5m': {api:'5m',  bars:500, resample:1}, '15m':{api:'15m', bars:500, resample:1},
  '30m':{api:'30m', bars:500, resample:1}, '1h': {api:'1h',  bars:500, resample:1},
  '2h': {api:'2h',  bars:500, resample:1}, '4h': {api:'4h',  bars:500, resample:1},
  '6h': {api:'6h',  bars:500, resample:1}, '8h': {api:'8h',  bars:500, resample:1},
  '12h':{api:'12h', bars:500, resample:1}, '1d': {api:'1d',  bars:500, resample:1},
  '3d': {api:'3d',  bars:500, resample:1}, '1w': {api:'1w',  bars:500, resample:1},
  '1M': {api:'1M',  bars:500, resample:1},
};
const NWE_TF_LABEL = {'1m':'1m','3m':'3m','5m':'5m','15m':'15m','30m':'30m','1h':'1h','2h':'2h','4h':'4h','6h':'6h','8h':'8h','12h':'12h','1d':'1d','3d':'3d','1w':'1w','1M':'1M'};
const NWE_TF_MINUTES = {'1m':1,'3m':3,'5m':5,'15m':15,'30m':30,'1h':60,'2h':120,'4h':240,'6h':360,'8h':480,'12h':720,'1d':1440,'3d':4320,'1w':10080,'1M':43200};
const NWE_TF_WEIGHT = {};
for (const tf in NWE_TF_MINUTES) NWE_TF_WEIGHT[tf] = Math.sqrt(NWE_TF_MINUTES[tf]);
const NWE_TF_CLUSTERS = [
  ['1m','3m','5m','15m'],
  ['30m','1h','2h','4h','6h','8h','12h'],
  ['1d','3d','1w','1M'],
];
function nweComputeScore(tfs) {
  let total = 0;
  for (const cluster of NWE_TF_CLUSTERS) {
    const active = tfs.filter(tf => cluster.includes(tf));
    active.sort((a,b) => NWE_TF_WEIGHT[b] - NWE_TF_WEIGHT[a]);
    active.forEach((tf, idx) => { total += NWE_TF_WEIGHT[tf] * Math.pow(0.7, idx); });
  }
  return Math.round(total * 10) / 10;
}

let nweSelectedTFs = ['1h'], nweScanning = false, nweScanResults = [], nweActiveTab = 'all';
let nweTop10Buys = [], nweTop10Sells = [], nweManualData = null;

function nweGauss(x, h) { return Math.exp(-(x*x)/(h*h*2)); }

function nweComputeNWE(closes, h, mult) {
  const n = closes.length;
  const WIN = Math.min(499, n - 1);
  const gaussCache = new Map();
  const g = (x) => { if (!gaussCache.has(x)) gaussCache.set(x, nweGauss(x, h)); return gaussCache.get(x); };
  const src = new Array(WIN + 1);
  for (let j = 0; j <= WIN; j++) src[j] = closes[n - 1 - j];
  const nwe2 = new Array(WIN + 1);
  let sae = 0;
  for (let i = 0; i <= WIN; i++) {
    let sum = 0, sumw = 0;
    for (let j = 0; j <= WIN; j++) { const w = g(i - j); sum += src[j] * w; sumw += w; }
    nwe2[i] = sum / sumw;
    sae += Math.abs(src[i] - nwe2[i]);
  }
  sae = (sae / WIN) * mult;
  const nwe = new Array(n).fill(null);
  for (let i = 0; i <= WIN; i++) nwe[n - 1 - i] = nwe2[i];
  for (let T = n - WIN - 2; T >= 0; T--) nwe[T] = nwe[n - WIN - 1];
  const maeArr = new Array(n).fill(sae);
  const out = nwe[n - 1], mae = maeArr[n - 1];
  return { nwe, maeArr, out, mae, upper: out + mae, lower: out - mae };
}

function nweLookbackForTF(tf) {
  const w = NWE_TF_WEIGHT[tf] || 6;
  if (w <= 4) return 5;
  if (w <= 11) return 3;
  return 2;
}

function nweDetectSignal(closes, nwe, maeArr, lookback) {
  const n = closes.length;
  let isBuy = false, isSell = false;
  for (let T = Math.max(1, n - lookback); T < n; T++) {
    const bandU = nwe[T] + maeArr[T];
    const bandL = nwe[T] - maeArr[T];
    if (closes[T] > bandU && closes[T-1] < bandU) isSell = true;
    if (closes[T] < bandL && closes[T-1] > bandL) isBuy  = true;
  }
  const U = i => nwe[i] + maeArr[i];
  const L = i => nwe[i] - maeArr[i];
  return { isBuy, isSell, upper: U(n-1), lower: L(n-1), center: nwe[n-1] };
}

let nweActiveSymbolsCache = null, nweActiveSymbolsCacheTime = 0;
async function nweGetActiveSymbols() {
  if (nweActiveSymbolsCache && Date.now() - nweActiveSymbolsCacheTime < 10*60*1000) return nweActiveSymbolsCache;
  const r = await fetch('https://api.binance.com/api/v3/exchangeInfo');
