<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
/* ================= CONFIG ================= */
const TF_LABELS = { '15m':'15 DAKİKALIK', '1h':'1 SAATLİK', '4h':'4 SAATLİK', '1d':'GÜNLÜK', '1w':'1 HAFTALIK', '1M':'AYLIK', '3M':'3 AYLIK' };
const TF_ORDER = ['3M','1M','1w','1d','4h','1h','15m']; 
const CONCURRENCY = 8;

let topN = 100;
let selectedTFs = ['4h','1d','1w'];
let selectedPatterns = ['diamond','mat','dca'];
let scanning = false;
let stopRequested = false;
let results = []; // {tf, tfLabel, base, symbol, pattern, subtype?} pattern: 'diamond' | 'mat' | 'dca' (subtype: 'bear' | 'bull' for dca)
let scanStartTime = 0;
let lastScanMeta = null; 

/* ================= PATTERN LOGIC ================= */
function isDiamond(c){
  if(c.length < 3) return false;
  const curr = c[c.length-1], prev = c[c.length-2], prev2 = c[c.length-3];
  return (curr.high < prev.high && prev.high > prev2.high) &&
         (curr.low > prev.low && prev.low < prev2.low);
}

function isMatHold(c){
  if(c.length < 4) return false;
  const c1 = c[c.length-4], c2 = c[c.length-3], c3 = c[c.length-2], c4 = c[c.length-1];
  const body = x => Math.abs(x.close - x.open);
  const avgOthers = (body(c2) + body(c3) + body(c4)) / 3;
  const cond1 = (c1.close > c1.open) && (body(c1) > avgOthers * 1.5);
  const cond2 = Math.max(c2.high, c3.high, c4.high) < c1.high;
  const cond3 = Math.min(c2.low, c3.low, c4.low) >= c1.open;
  return cond1 && cond2 && cond3;
}

// YENİ ENTEGRASYON: DCA Metodu (Bear + Bull)
// Ortak mantık: bir "mother bar", kendinden sonraki "inside bar"ın hem high hem low'unu sarmalamalı (engulfing).
// Not: mum rengi (yeşil/kırmızı) şartı YOK — sadece high/low ilişkileri önemli.

// DCA BEAR: mother bar bir SWING LOW'dur (solundaki 5 bar ve sağındaki tüm barlardan daha düşük low),
// ardından gelen barlar ardışık olarak daha YÜKSEK HIGH yaparak yükselen bir zincir oluşturur.
function isDcaBear(c){
  if(c.length < 9) return false; // solunda 5 bar + mother bar + inside bar + en az 3 ardışık bar olmalı

  for (let i = 5; i < c.length - 2; i++) {
    const motherBar = c[i];
    const insideBar = c[i+1];

    // Mother Bar & Inside Bar kontrolü (mother bar, inside bar'ın hem high hem low'unu aşmalı)
    if (motherBar.high > insideBar.high && motherBar.low < insideBar.low) {

      // Mother bar'ın low'u solundaki 5 barın low'undan düşük olmalı
      let leftLow = Infinity;
      for (let k = i - 5; k <= i - 1; k++) leftLow = Math.min(leftLow, c[k].low);

      // Mother bar'ın low'u, kendisinden sonra güncel mevcut bara kadar olan TÜM barların low'undan da düşük olmalı
      let rightLow = Infinity;
      for (let k = i + 1; k < c.length; k++) rightLow = Math.min(rightLow, c[k].low);

      if (!(motherBar.low < leftLow && motherBar.low < rightLow)) continue;

      let barCount = 1;
      let isChainValid = true;

      // İçsel bardan sonraki barların ardışık yüksek tepeler yapıp yapmadığını ölçelim
      for (let j = i + 2; j < c.length; j++) {
        if (c[j].high > c[j-1].high) {
          barCount++;
        } else {
          isChainValid = false;
          break;
        }
      }

      // Zincir bozulmadan geldiyse ve bar sayısı 3, 6, 7, 8, 9 değerlerinden biriyse tetiklenir
      if (isChainValid && (barCount === 3 || (barCount >= 6 && barCount <= 9))) {
        return true;
      }
    }
  }
  return false;
}

// DCA BULL: mother bar bir SWING HIGH'dır (solundaki 5 bar ve sağındaki tüm barlardan daha yüksek high),
// ardından gelen barlar ardışık olarak daha DÜŞÜK LOW yaparak düşen bir zincir oluşturur. (DCA Bear'ın aynası)
function isDcaBull(c){
  if(c.length < 9) return false;

  for (let i = 5; i < c.length - 2; i++) {
    const motherBar = c[i];
    const insideBar = c[i+1];

    if (motherBar.high > insideBar.high && motherBar.low < insideBar.low) {

      // Mother bar'ın high'ı solundaki 5 barın high'ından yüksek olmalı
      let leftHigh = -Infinity;
      for (let k = i - 5; k <= i - 1; k++) leftHigh = Math.max(leftHigh, c[k].high);

      // Mother bar'ın high'ı, kendisinden sonra güncel mevcut bara kadar olan TÜM barların high'ından da yüksek olmalı
      let rightHigh = -Infinity;
      for (let k = i + 1; k < c.length; k++) rightHigh = Math.max(rightHigh, c[k].high);

      if (!(motherBar.high > leftHigh && motherBar.high > rightHigh)) continue;

      let barCount = 1;
      let isChainValid = true;

      // İçsel bardan sonraki barların ardışık daha düşük dipler yapıp yapmadığını ölçelim
      for (let j = i + 2; j < c.length; j++) {
        if (c[j].low < c[j-1].low) {
          barCount++;
        } else {
          isChainValid = false;
          break;
        }
      }

      if (isChainValid && (barCount === 3 || (barCount >= 6 && barCount <= 9))) {
        return true;
      }
    }
  }
  return false;
}

/* ================= BINANCE FETCH HELPERS ================= */
async function fetchTopVolumeCoins(limit){
  const res = await fetch('https://api.binance.com/api/v3/ticker/24hr');
  if(!res.ok) throw new Error('ticker http '+res.status);
  const data = await res.json();
  const usdt = data.filter(d=>{
    if(!d.symbol.endsWith('USDT')) return false;
    const base = d.symbol.slice(0, -4);
    if(base.endsWith('UP') || base.endsWith('DOWN')) return false; 
    return true;
  });
  usdt.sort((a,b)=> parseFloat(b.quoteVolume) - parseFloat(a.quoteVolume));
  return usdt.slice(0, limit).map(d=>({ symbol:d.symbol, base:d.symbol.slice(0,-4) }));
}

async function fetchKlinesRaw(symbol, interval, limit, attempt){
  attempt = attempt || 0;
  const url = `https://api.binance.com/api/v3/klines?symbol=${symbol}&interval=${interval}&limit=${limit}`;
  const res = await fetch(url);
  if(res.status === 429 && attempt < 2){
    await new Promise(r=>setTimeout(r, 900*(attempt+1)));
    return fetchKlinesRaw(symbol, interval, limit, attempt+1);
  }
  if(!res.ok) throw new Error('klines http '+res.status);
  const raw = await res.json();
  return raw.map(k=>({ open:parseFloat(k[1]), high:parseFloat(k[2]), low:parseFloat(k[3]), close:parseFloat(k[4]) }));
}

async function fetchCandles(symbol, tfKey){
  // dcabear için: solda 3 bar + mother + inside + en fazla 9 ardışık bar zinciri gerektiğinden pencere 20'ye yükseltildi
  if(tfKey !== '3M') return fetchKlinesRaw(symbol, tfKey, 20);
  
  const monthly = await fetchKlinesRaw(symbol, '1M', 60);
  const quarters = [];
  for(let i=0; i+2 < monthly.length; i+=3){
    const trio = [monthly[i], monthly[i+1], monthly[i+2]];
    quarters.push({
      open: trio[0].open,
      close: trio[2].close,
      high: Math.max(trio[0].high, trio[1].high, trio[2].high),
      low: Math.min(trio[0].low, trio[1].low, trio[2].low),
    });
  }
  return quarters.slice(-20);
}

/* ================= CONCURRENCY POOL ================= */
async function runPool(items, worker, concurrency, onProgress){
  let idx = 0;
  const total = items.length;
  let completed = 0;
  async function runner(){
    while(idx < total){
      if(stopRequested) return;
      const i = idx++;
      try{ await worker(items[i]); }catch(e){ }
      completed++;
      onProgress(completed, total);
    }
  }
  const runners = Array.from({length:Math.min(concurrency, total)}, runner);
  await Promise.all(runners);
}

/* ================= UI HELPERS ================= */
const $ = id => document.getElementById(id);
function setPhase(label, pct){
  $('phaseLabel').innerHTML = label;
  $('phasePct').textContent = pct==null ? '' : pct+'%';
  $('progFill').style.width = (pct||0)+'%';
}

/* ================= MAIN SCAN ================= */
async function startScan(){
  if(selectedTFs.length === 0){ alert('En az bir zaman dilimi seçmelisiniz.'); return; }
  if(selectedPatterns.length === 0){ alert('En az bir formasyon seçmelisiniz.'); return; }
  scanning = true; stopRequested = false;
  results = [];
  scanStartTime = performance.now();
  $('scanBtn').textContent = '■ DURDUR';
  $('scanBtn').classList.add('stop');
  document.querySelectorAll('#topNChips .chip, #tfChips .chip, #patternChips .chip, #customNInput').forEach(el=>el.style.pointerEvents='none');
  $('statsRow').style.display = 'flex';
  $('idleState').style.display = 'none';
  $('emptyState').style.display = 'none';
  $('tableWrap').style.display = 'none';
  $('csvBtn').disabled = true; $('pngBtn').disabled = true;
  updateStats();

  setPhase('Binance top hacim listesi çekiliyor…', 0);
  let coins = [];
  try{
    coins = await fetchTopVolumeCoins(topN);
  }catch(e){
    setPhase('Hata: liste çekilemedi ('+e.message+')', 0);
    finishScan();
    return;
  }

  const tfsToRun = TF_ORDER.filter(tf=>selectedTFs.includes(tf));
  let scannedCount = 0;
  const totalScanned = coins.length * tfsToRun.length;

  for(const tf of tfsToRun){
    if(stopRequested) break;
    const tfLabel = TF_LABELS[tf];
    await runPool(coins, async (coin)=>{
      const candles = await fetchCandles(coin.symbol, tf);
      if(selectedPatterns.includes('diamond') && isDiamond(candles)) results.push({ tf, tfLabel, base:coin.base, symbol:coin.symbol, pattern:'diamond' });
      if(selectedPatterns.includes('mat') && isMatHold(candles)) results.push({ tf, tfLabel, base:coin.base, symbol:coin.symbol, pattern:'mat' });
      if(selectedPatterns.includes('dca')){
        if(isDcaBear(candles)) results.push({ tf, tfLabel, base:coin.base, symbol:coin.symbol, pattern:'dca', subtype:'bear' });
        if(isDcaBull(candles)) results.push({ tf, tfLabel, base:coin.base, symbol:coin.symbol, pattern:'dca', subtype:'bull' });
      }
    }, CONCURRENCY, (done, total)=>{
      scannedCount++;
      const pct = Math.round((scannedCount/totalScanned)*100);
      setPhase(`<b>${tfLabel}</b> periyodu taranıyor… (${done}/${total})`, pct);
      updateStats();
    });
  }

  setPhase(stopRequested ? 'Tarama durduruldu' : 'Tarama tamamlandı', 100);
  const now = new Date();
  lastScanMeta = {
    topN: coins.length,
    tfLabels: tfsToRun.map(tf=>TF_LABELS[tf]),
    dateStr: now.toLocaleDateString('tr-TR') + ' ' + now.toLocaleTimeString('tr-TR', {hour:'2-digit', minute:'2-digit'})
  };
  finishScan();
}

function finishScan(){
  scanning = false;
  $('scanBtn').textContent = '▶ TARAMAYI BAŞLAT';
  $('scanBtn').classList.remove('stop');
  document.querySelectorAll('#topNChips .chip, #tfChips .chip, #patternChips .chip, #customNInput').forEach(el=>el.style.pointerEvents='');
  $('gemIcon').classList.remove('scanning');
  updateStats();
  renderResults();
}

function updateStats(){
  const elapsed = ((performance.now() - scanStartTime)/1000).toFixed(1);
  $('statScanned').textContent = results.length ? results.length : results.length;
  $('statDiamond').textContent = results.filter(r=>r.pattern==='diamond').length;
  $('statMat').textContent = results.filter(r=>r.pattern==='mat').length;
  $('statDcaBear').textContent = results.filter(r=>r.pattern==='dca').length;
  $('statTime').textContent = elapsed+'s';
}

/* ================= RESULTS RENDER / FILTER ================= */
let activeFilter = 'all';
let searchText = '';
let currentFiltered = [];

function renderResults(){
  const filtered = results.filter(r=>{
    if(activeFilter !== 'all' && r.pattern !== activeFilter) return false;
    if(searchText && !r.base.toLowerCase().includes(searchText.toLowerCase())) return false;
    return true;
  });
  currentFiltered = filtered;

  $('csvBtn').disabled = results.length === 0;
  $('pngBtn').disabled = currentFiltered.length === 0;

  if(results.length === 0){
    $('idleState').style.display = 'none';
    $('emptyState').style.display = 'block';
    $('tableWrap').style.display = 'none';
    return;
  }
  $('idleState').style.display = 'none';
  $('emptyState').style.display = filtered.length ? 'none' : 'block';
  $('tableWrap').style.display = filtered.length ? 'block' : 'none';

  $('resultsBody').innerHTML = filtered.map(r=>{
    let badge = '';
    if(r.pattern === 'diamond') badge = `<span class="badge diamond">💎 DIAMOND</span>`;
    if(r.pattern === 'mat') badge = `<span class="badge mat">🚀 B.M HOLD</span>`;
    if(r.pattern === 'dca') badge = r.subtype === 'bull'
      ? `<span class="badge dca-bull">🐂 DCA (BULL)</span>`
      : `<span class="badge dca-bear">🦊 DCA (BEAR)</span>`;
    
    return `<tr>
      <td><span class="tf-tag">${r.tfLabel}</span></td>
      <td><a class="coin-link" href="https://www.binance.com/en/trade/${r.base}_USDT" target="_blank" rel="noopener">
        ${r.base}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10"/></svg>
      </a></td>
      <td>${badge}</td>
    </tr>`;
  }).join('');
}

/* ================= EXPORT ================= */
function timestamp(){
  const d = new Date();
  const p = n=>String(n).padStart(2,'0');
  return `${d.getFullYear()}${p(d.getMonth()+1)}${p(d.getDate())}-${p(d.getHours())}${p(d.getMinutes())}`;
}
function downloadCSV(){
  const rows = [['Periyot','Coin','Formasyon']];
  results.forEach(r=>{
    let patName = 'DIAMOND';
    if(r.pattern === 'mat') patName = 'BULLISH MAT HOLD';
    if(r.pattern === 'dca') patName = r.subtype === 'bull' ? 'DCA (BULL)' : 'DCA (BEAR)';
    rows.push([r.tfLabel, r.base, patName]);
  });
  const csv = rows.map(row=> row.map(v=>`"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob(['\uFEFF'+csv], {type:'text/csv;charset=utf-8;'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `pro-scanner-${timestamp()}.csv`;
  a.click();
}
function exportTitle(){
  if(activeFilter === 'diamond') return '💎 Diamond Formasyon Sonuçları';
