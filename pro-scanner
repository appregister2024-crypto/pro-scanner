    ctx.fillText(label+'  ·  '+count+' TF', x+18, badgeY+22);
    ctx.fillStyle=color; ctx.font='800 38px "JetBrains Mono", monospace';
    ctx.fillText('★ '+score, x+16, badgeY+60);
  };
  drawScoreBadge(padX, buyScore, buyTFs.length, 'ALIM SKORU', '#43dd8b');
  drawScoreBadge(padX+badgeW+16, sellScore, sellTFs.length, 'SATIM SKORU', '#ff5d72');

  cy = badgeY+badgeH+20;
  ctx.strokeStyle='rgba(216,184,119,0.2)'; ctx.beginPath(); ctx.moveTo(padX,cy); ctx.lineTo(W-padX,cy); ctx.stroke();

  const maxWeight = Math.max(...tfs.map(tf=>NWE_TF_WEIGHT[tf]||1));
  let y = HEADER_H;
  tfs.forEach((tf, idx) => {
    const sig = sigMap[tf];
    const status = sig.isBuy?'buy':sig.isSell?'sell':'none';
    const color = status==='buy'?'#43dd8b':status==='sell'?'#ff5d72':'#525a6e';
    const label = status==='buy'?'▲ ALIM':status==='sell'?'▼ SATIM':'— nötr';
    const pct = (NWE_TF_WEIGHT[tf]||1)/maxWeight;
    if (idx%2===0) { ctx.fillStyle='rgba(255,255,255,0.015)'; nweRoundRect(ctx, padX-10, y-6, W-padX*2+20, ROW_H-12, 8); ctx.fill(); }
    ctx.fillStyle='#eef1f8'; ctx.font='700 18px "JetBrains Mono", monospace'; ctx.fillText(NWE_TF_LABEL[tf], padX, y+20);
    const barX = padX+80, barW = W-padX*2-80-160;
    ctx.fillStyle='rgba(255,255,255,0.06)'; nweRoundRect(ctx, barX, y+12, barW, 7, 4); ctx.fill();
    ctx.fillStyle=color; ctx.globalAlpha = status==='none'?0.3:0.9;
    nweRoundRect(ctx, barX, y+12, barW*pct, 7, 4); ctx.fill(); ctx.globalAlpha=1;
    ctx.fillStyle=color; ctx.font='700 16px "JetBrains Mono", monospace'; ctx.textAlign='right';
    ctx.fillText(label, W-padX, y+20); ctx.textAlign='left';
    y += ROW_H;
  });

  const fy = H-FOOTER_H;
  ctx.strokeStyle='rgba(255,255,255,0.06)'; ctx.beginPath(); ctx.moveTo(padX,fy); ctx.lineTo(W-padX,fy); ctx.stroke();
  ctx.fillStyle='#525a6e'; ctx.font='500 14px "Inter", sans-serif';
  ctx.fillText('Nadaraya-Watson Envelope sinyal tarayıcısı', padX, fy+34);
  ctx.fillStyle='#d8b877'; ctx.font='700 15px "JetBrains Mono", monospace'; ctx.textAlign='right';
  ctx.fillText('K(x) = e^(−x²/2h²)', W-padX, fy+34); ctx.textAlign='left';

  const link = document.createElement('a');
  link.download = `nwe-scanner-${sym}-${timestamp()}.png`;
  link.href = canvas.toDataURL('image/png', 1.0);
  link.click();
}
document.getElementById('nweManualPngBtn').addEventListener('click', nweGenerateManualShareImage);
</script>
</body>
