async function nweRunScan() {
  if (nweScanning) return;
  nweScanning = true;
  const btn = $('nweScanBtn');
  btn.textContent = '■ Taranıyor…'; btn.classList.add('stop');
  document.querySelectorAll('#nweTfChips .chip, #nweBw, #nweMult, #nweTopN').forEach(el=>el.style.pointerEvents='none');

  const h = parseFloat($('nweBw').value), mult = parseFloat($('nweMult').value), topNVal = parseInt($('nweTopN').value);
  const tfs = [...nweSelectedTFs];
  const isMTF = tfs.length > 1;
  const t0 = Date.now();

  $('nweStatsRow').style.display = 'flex';
  nweSetPhase('Semboller yükleniyor…', 0);

  let symbols;
  try { symbols = await nweGetTopSymbols(topNVal); }
  catch(e) { nweSetPhase('Hata: '+e.message, 0); nweEndScan(); return; }

  const total = symbols.length;
  let done = 0;
  nweScanResults = [];

  for (let i = 0; i < total; i += NWE_BATCH) {
    const batch = symbols.slice(i, i+NWE_BATCH);
    await Promise.all(batch.map(async ({ symbol, price }) => {
      const sigMap = {};
      for (const tf of tfs) {
        try {
          const closes = await nweGetKlines(symbol, tf);
          if (closes.length < 20) continue;
          const { nwe, maeArr } = nweComputeNWE(closes, h, mult);
          sigMap[tf] = nweDetectSignal(closes, nwe, maeArr, nweLookbackForTF(tf));
        } catch(e) {}
      }
      const buyTFs  = tfs.filter(tf => sigMap[tf]?.isBuy);
      const sellTFs = tfs.filter(tf => sigMap[tf]?.isSell);
      if (buyTFs.length || sellTFs.length) {
        nweScanResults.push({
          sym: symbol, price, sigMap, buyTFs, sellTFs,
          hasBuy: buyTFs.length>0, hasSell: sellTFs.length>0,
          strongBuy: isMTF && buyTFs.length>=2, strongSell: isMTF && sellTFs.length>=2,
          buyScore: nweComputeScore(buyTFs), sellScore: nweComputeScore(sellTFs), tfs
        });
      }
      done++;
      const pct = Math.round((done/total)*100);
      nweSetPhase(`<b>${symbol}</b> taranıyor… (${done}/${total})`, pct);
    }));
    if (i+NWE_BATCH < total) await nweSleep(NWE_DELAY);
  }

  const elapsed = ((Date.now()-t0)/1000).toFixed(1);
  nweSetPhase('Tarama tamamlandı', 100);
  nweRenderResults(tfs, symbols.length, elapsed);
  nweEndScan();
}

